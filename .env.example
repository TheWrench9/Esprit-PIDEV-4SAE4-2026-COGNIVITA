# ── Database ──────────────────────────────────────────────────────────────────
# DB_USER and DB_PASSWORD are used by all services.
# The root password is set in docker-compose.yml directly.
DB_PASSWORD=rootpassword

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# Used by: notification-service, medical-records-service
# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=alzheimer.alerts@gmail.com

# ── Email report targets ───────────────────────────────────────────────────────
REPORT_FROM_EMAIL=noreply@alzheimer.app
REPORT_DOCTOR_EMAIL=doctor@alzheimer.app

# ── Twilio SMS (optional) ──────────────────────────────────────────────────────
# Leave TWILIO_ENABLED=false to disable SMS — email + in-app still work.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ── Escalation timing (hours) ─────────────────────────────────────────────────
# How long after a missed dose before caregiver is notified
MISSED_DOSE_HOURS=48
# How long after caregiver notification before doctor is notified
CAREGIVER_HOURS=24
# How many hours past scheduled time before a dose is flagged as MISSED
MISSED_DOSE_THRESHOLD_HOURS=4
